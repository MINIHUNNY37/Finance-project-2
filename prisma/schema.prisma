generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedMap {
  id        String   @id @default(cuid())
  userId    String
  mapId     String
  name      String
  data      String   // JSON blob of the full ScenarioMap
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mapId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      String   @default("user") // "user" | "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime?
}
