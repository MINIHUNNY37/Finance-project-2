generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedMap {
  id        String   @id @default(cuid())
  userId    String
  mapId     String
  name      String
  data      String // JSON blob of the full ScenarioMap
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, mapId])
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  role      String    @default("user") // "user" | "admin"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?
}

// ── Market Universe ──────────────────────────────────────────────────────────

model StockUniverse {
  id          String   @id @default(cuid())
  ticker      String   @unique
  name        String
  exchange    String // "NASDAQ" | "NYSE" | "NYSE ARCA"
  sector      String?
  industry    String?
  country     String   @default("US")
  isNasdaq100 Boolean  @default(false)
  isSP500     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ohlc           StockDailyOHLC[]
  quarterlyStats StockQuarterlyStats[]
  dividends      StockDividend[]
  splits         StockSplit[]
}

// ── Daily OHLC (2024-2026, expandable) ──────────────────────────────────────
// Composite PK on (ticker, date) — no wasted id column.
// adjClose accounts for splits and dividends (use for backtesting).

model StockDailyOHLC {
  ticker   String
  date     DateTime @db.Date
  open     Float
  high     Float
  low      Float
  close    Float
  adjClose Float?
  volume   BigInt   @default(0)

  stock StockUniverse @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@id([ticker, date])
  @@index([ticker, date(sort: Desc)])
}

// ── Quarterly & snapshot statistics ─────────────────────────────────────────
// reportType: "Q1" | "Q2" | "Q3" | "Q4" | "Annual" | "snapshot"
// "snapshot" is written by the seed-markets live-quote step.
// Quarterly rows are written by seed-history step.

model StockQuarterlyStats {
  ticker     String
  periodEnd  DateTime @db.Date // quarter-end date (or today for snapshots)
  reportType String // "Q1"|"Q2"|"Q3"|"Q4"|"Annual"|"snapshot"

  // ── Price snapshot ──────────────────────────────────────────────────────
  price          Float?
  priceChange    Float?
  priceChangePct Float?
  week52High     Float?
  week52Low      Float?

  // ── Valuation ───────────────────────────────────────────────────────────
  marketCap    Float? // raw value in USD
  marketCapFmt String? // formatted, e.g. "$2.50T"
  peRatio      Float?
  priceToBook  Float?

  // ── Income statement ────────────────────────────────────────────────────
  revenue        Float?
  netIncome      Float?
  eps            Float? // actual EPS
  epsEstimate    Float?
  epsSurprisePct Float?

  // ── Balance sheet ───────────────────────────────────────────────────────
  bookValue    Float?
  debtToEquity Float?
  currentRatio Float?

  // ── Cash flow ───────────────────────────────────────────────────────────
  freeCashFlow      Float?
  operatingCashFlow Float?

  // ── Returns / yield ─────────────────────────────────────────────────────
  operatingMargin Float?
  dividendYield   Float? // decimal, e.g. 0.0052 for 0.52%

  reportedAt DateTime? // when earnings were officially published
  fetchedAt  DateTime  @default(now())

  stock StockUniverse @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@id([ticker, periodEnd, reportType])
  @@index([ticker, periodEnd(sort: Desc)])
}

// ── Dividend history ─────────────────────────────────────────────────────────

model StockDividend {
  ticker    String
  exDate    DateTime  @db.Date
  payDate   DateTime? @db.Date
  amount    Float // dividend per share in USD
  frequency String? // "quarterly" | "monthly" | "annual" | "special"

  stock StockUniverse @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@id([ticker, exDate])
  @@index([ticker, exDate(sort: Desc)])
}

// ── Stock split history ───────────────────────────────────────────────────────

model StockSplit {
  ticker String
  date   DateTime @db.Date
  ratio  Float // e.g. 4.0 for a 4-for-1 split

  stock StockUniverse @relation(fields: [ticker], references: [ticker], onDelete: Cascade)

  @@id([ticker, date])
}

// ── Ingestion progress tracker ────────────────────────────────────────────────
// Enables resumable batch seeding across all tickers.
// dataType: "ohlc" | "quarterly"

model StockFetchProgress {
  ticker        String
  dataType      String // "ohlc" | "quarterly"
  status        String    @default("pending") // "pending" | "done" | "failed"
  lastFetchedAt DateTime?
  errorMessage  String?

  @@id([ticker, dataType])
  @@index([dataType, status])
}

// ── DB Schema Manager ────────────────────────────────────────────────────────
// Stores user-defined table/column definitions for the database dashboard.
// Actual fin_* tables are created separately via the /sync endpoint.

model DbTableSchema {
  id          String           @id @default(cuid())
  tableName   String           @unique // SQL name, e.g. "fin_stock_info"
  displayName String // UI label, e.g. "Stock Info"
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  columns     DbColumnSchema[]
}

model DbColumnSchema {
  id           String   @id @default(cuid())
  tableId      String
  columnName   String // SQL column name, e.g. "ticker"
  displayName  String // UI label, e.g. "Ticker"
  dataType     String   @default("TEXT") // TEXT | NUMERIC | INTEGER | BOOLEAN | TIMESTAMPTZ
  isPrimaryKey Boolean  @default(false)
  isForeignKey Boolean  @default(false)
  foreignTable String? // SQL table name of referenced table
  isNullable   Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  table DbTableSchema @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, columnName])
}

// Pre-built template maps available to all users
model TemplateMap {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String // "markets" | "geopolitics" etc.
  data        String // JSON blob: ScenarioMap
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Company library system ──────────────────────────────────────────────────
// Replaces the single-list StockUniverse with flexible, admin-curated libraries.
// A company can belong to multiple libraries.

model Company {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  exchange  String?
  sector    String?
  industry  String?
  country   String   @default("US")
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        CompanyLibraryMembership[]
  periods            CompanyPeriod[]
  dailyPrices        CompanyDailyPrice[]
  corporateActions   CompanyCorporateAction[]
  ingestionRuns      CompanyIngestionRun[]
  screeningSnapshots CompanyScreeningSnapshot[]
}

model CompanyLibrary {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "nasdaq100", "us-big-tech"
  title       String
  description String   @default("")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships CompanyLibraryMembership[]
}

model CompanyLibraryMembership {
  id        String   @id @default(cuid())
  libraryId String
  companyId String
  sortOrder Int      @default(0)
  addedAt   DateTime @default(now())

  library CompanyLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([libraryId, companyId])
  @@index([libraryId, sortOrder])
}

// ── Time-period axis ────────────────────────────────────────────────────────
// periodKey is the uniqueness anchor — avoids nullable compound unique constraint.
// Application layer generates it deterministically:
//   quarterly:  "Q-{year}-{quarter}"   e.g. "Q-2025-4"
//   annual:     "A-{year}"             e.g. "A-2024"
//   ttm:        "TTM-{YYYY-MM}"        e.g. "TTM-2025-03"
//   snapshot:   "SNAP-{YYYY-MM-DD}"    e.g. "SNAP-2025-03-29"

model CompanyPeriod {
  id                 String    @id @default(cuid())
  companyId          String
  periodKey          String // computed discriminator (see above)
  periodType         String // 'quarterly'|'annual'|'ttm'|'snapshot'
  fiscalYear         Int?
  fiscalQuarter      Int? // 1–4; null for non-quarterly types
  periodLabel        String // display string e.g. "2025 Q4", "FY2024"
  startDate          DateTime? @db.Date
  endDate            DateTime? @db.Date
  periodEndDate      DateTime? @db.Date
  reportedAt         DateTime?
  filingDate         DateTime?
  asOfDate           DateTime? @db.Date
  sourceProvider     String    @default("yahoo")
  restatementVersion Int       @default(1)
  isLatest           Boolean   @default(false) // exactly one true per (companyId, periodType)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  ingestionRunId     String?

  company            Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  metrics            CompanyMetricValue[]
  facts              CompanyFactValue[]
  screeningSnapshots CompanyScreeningSnapshot[]
  ingestionRun       CompanyIngestionRun?       @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([companyId, periodKey, restatementVersion])
  @@index([companyId, periodType, isLatest])
  @@index([companyId, periodType, periodEndDate(sort: Desc)])
}

// ── Metric catalogue ────────────────────────────────────────────────────────
// One row per metric type. Seeded once via /api/admin/seed-company-schema?step=1.

model CompanyMetricDefinition {
  id                     String @id @default(cuid())
  code                   String @unique // e.g. "valuation_pe", "quality_roe"
  label                  String // e.g. "PER", "ROE"
  category               String // "valuation"|"quality"|"risk"
  unitType               String // "ratio"|"percent"|"currency"|"number"
  formula                String @default("") // human-readable formula documentation
  description            String @default("")
  availableInPeriodTypes String @default("[]") // JSON array e.g. '["snapshot","ttm"]'
  sortOrder              Int    @default(0)

  values CompanyMetricValue[]
}

model CompanyFactDefinition {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  category    String
  unitType    String
  description String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  values CompanyFactValue[]
}

// ── Metric values ───────────────────────────────────────────────────────────
// companyId intentionally omitted — join via period → company to avoid
// the consistency risk of duplicating the foreign key.
// numericValue is null when the formula result is undefined (e.g. zero denominator).
// textValue is used for special sentinel strings e.g. "N/D" (no debt).

model CompanyMetricValue {
  id                 String   @id @default(cuid())
  periodId           String
  metricDefinitionId String
  numericValue       Float?
  textValue          String?
  currency           String? // only populated for unitType = 'currency'
  source             String   @default("system")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  formulaVersion     String   @default("v1")

  period     CompanyPeriod           @relation(fields: [periodId], references: [id], onDelete: Cascade)
  definition CompanyMetricDefinition @relation(fields: [metricDefinitionId], references: [id])

  @@unique([periodId, metricDefinitionId, formulaVersion])
  @@index([periodId])
}

model CompanyFactValue {
  id               String   @id @default(cuid())
  periodId         String
  factDefinitionId String
  numericValue     Float?
  textValue        String?
  currency         String?
  sourceProvider   String   @default("yahoo")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  ingestionRunId   String?

  period       CompanyPeriod         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  definition   CompanyFactDefinition @relation(fields: [factDefinitionId], references: [id])
  ingestionRun CompanyIngestionRun?  @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([periodId, factDefinitionId])
  @@index([periodId])
  @@index([factDefinitionId])
}

model CompanyCorporateAction {
  id             String   @id @default(cuid())
  companyId      String
  actionDate     DateTime @db.Date
  actionType     String
  amount         Float?
  ratio          Float?
  sharesDelta    Float?
  sourceProvider String   @default("yahoo")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, actionDate, actionType])
  @@index([companyId, actionDate(sort: Desc)])
}

model CompanyIngestionRun {
  id           String    @id @default(cuid())
  companyId    String?
  provider     String
  universeKey  String?
  jobType      String
  status       String    @default("pending")
  payloadHash  String?
  errorMessage String?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company            Company?                   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  periods            CompanyPeriod[]
  facts              CompanyFactValue[]
  screeningSnapshots CompanyScreeningSnapshot[]

  @@index([provider, jobType, status])
  @@index([companyId, startedAt(sort: Desc)])
  @@index([universeKey, startedAt(sort: Desc)])
}

model CompanyScreeningSnapshot {
  id                     String    @id @default(cuid())
  companyId              String
  sourcePeriodId         String?
  ingestionRunId         String?
  asOfDate               DateTime  @db.Date
  priceDate              DateTime? @db.Date
  snapshotType           String
  formulaVersion         String    @default("v1")
  sourceProvider         String    @default("system")
  per                    Float?
  pbr                    Float?
  evEbit                 Float?
  fcfYield               Float?
  valuationPercentile    Float?
  revenueGrowth          Float?
  operatingMargin        Float?
  roe                    Float?
  roic                   Float?
  cfoNetIncomeRatio      Float?
  fcf                    Float?
  netDebtEbitda          Float?
  interestCoverage       Float?
  cashShortTermDebtRatio Float?
  shareholderYield       Float?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourcePeriod CompanyPeriod?       @relation(fields: [sourcePeriodId], references: [id], onDelete: SetNull)
  ingestionRun CompanyIngestionRun? @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([companyId, asOfDate, snapshotType, formulaVersion])
  @@index([snapshotType, asOfDate(sort: Desc)])
  @@index([companyId, snapshotType, asOfDate(sort: Desc)])
  @@index([per])
  @@index([roic])
  @@index([netDebtEbitda])
}

// ── Daily price candles ──────────────────────────────────────────────────────
// Replaces StockDailyOHLC once migration is complete (Phase 3).

model CompanyDailyPrice {
  companyId      String
  date           DateTime @db.Date
  open           Float?
  high           Float?
  low            Float?
  close          Float?
  adjustedClose  Float?
  volume         BigInt?
  sourceProvider String   @default("yahoo")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, date])
  @@index([companyId, date(sort: Desc)])
}
